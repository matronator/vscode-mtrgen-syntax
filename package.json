{
  "name": "mtrgen-syntax",
  "displayName": "mtrgen-syntax",
  "description": "Adds syntax highlighting for MTRGen templates",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Programming Languages", "Snippets", "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configurationDefaults": {
      "files.associations": {
        "Dockerfile.mtr": "mtrgen-dockerfile",
        "*.bash.mtr": "mtrgen-shellscript",
        "*.c.mtr": "mtrgen-c",
        "*.cjs.mtr": "mtrgen-javascript",
        "*.clar.mtr": "mtrgen-clarity",
        "*.cpp.mtr": "mtrgen-cpp",
        "*.cppm.mtr": "mtrgen-cpp",
        "*.cc.mtr": "mtrgen-cpp",
        "*.ccm.mtr": "mtrgen-cpp",
        "*.cs.mtr": "mtrgen-csharp",
        "*.css.mtr": "mtrgen-css",
        "*.cts.mtr": "mtrgen-typescript",
        "*.cxx.mtr": "mtrgen-cpp",
        "*.cxxm.mtr": "mtrgen-cpp",
        "*.elm.mtr": "mtrgen-elm",
        "*.erb.mtr": "mtrgen-ruby",
        "*.ex.mtr": "mtrgen-elixir",
        "*.exs.mtr": "mtrgen-elixir",
