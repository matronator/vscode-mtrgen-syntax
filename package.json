{
  "name": "mtrgen-syntax",
  "displayName": "MTRGen Templates Support - Syntax Highlighting, File Creation and more...",
  "description": "Adds syntax highlighting for MTRGen templates and a command to create files from MTRGen templates.",
  "version": "0.1.1",
  "publisher": "Matronator",
  "author": {
    "name": "Matronator",
    "email": "info@matronator.cz",
    "url": "https://matronator.cz"
  },
  "license": "MIT",
  "homepage": "https://github.com/matronator/vscode-mtrgen-syntax#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/matronator/vscode-mtrgen-syntax.git"
  },
  "bugs": {
    "url": "https://github.com/matronator/vscode-mtrgen-syntax/issues"
  },
  "qna": "marketplace",
  "galleryBanner": {
    "color": "#990000",
    "theme": "dark"
  },
  "icon": "icon-256.png",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "sponsor": {
    "url": "https://github.com/sponsors/matronator"
  },
  "funding": [
    {
      "type": "patreon",
      "url": "https://www.patreon.com/bePatron?u=34136375"
    },
    {
      "type": "paypal",
      "url": "https://www.paypal.com/paypalme/matronator"
    },
    {
      "type": "ko-fi",
      "url": "https://ko-fi.com/matronator"
    },
    {
      "type": "github",
      "url": "https://github.com/sponsors/matronator"
    }
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "mtrgenSyntax.createFileFromTemplate",
        "title": "Create File from MTRGen Template",
        "category": "MTRGen",
        "icon": "$(new-file)"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "mtrgenSyntax.createFileFromTemplate",
          "when": "resourceScheme == file",
          "group": "navigation@8"
        }
      ],
      "view/title": [
        {
          "command": "mtrgenSyntax.createFileFromTemplate",
          "when": "view == explorer",
          "group": "navigation"
        }
      ]
    },
    "configurationDefaults": {
