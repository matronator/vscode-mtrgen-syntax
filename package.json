        "language": "mtrgen-php",
        "scopeName": "source.mtrgen.php",
        "path": "./syntaxes/mtrgen.php.tmLanguage.json",
        "embeddedLanguages": {
          "source.php": "php",
          "text.html.php": "php",
          "source.mtrgen.tag": "mtrgen"
        }
