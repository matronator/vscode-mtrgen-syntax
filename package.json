    "languages": [
      {
        "id": "mtrgen",
        "aliases": [
          "MTRGen"
        ],
        "extensions": [
          ".mtr"
        ],
        "firstLine": "^--- MTRGEN ---\\s*$",
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./images/mtrgen-icon-light.svg",
          "dark": "./images/mtrgen-icon-dark.svg"
        }
