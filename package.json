        "*.rb.mtr": "mtrgen-ruby",
        "*.rbx.mtr": "mtrgen-ruby",
        "*.rbi.mtr": "mtrgen-ruby",
        "*.rjs.mtr": "mtrgen-ruby",
        "*.rake.mtr": "mtrgen-ruby",
        "*.rs.mtr": "mtrgen-rust",
        "*.ru.mtr": "mtrgen-ruby",
