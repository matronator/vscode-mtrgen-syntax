        "*.hpp.mtr": "mtrgen-cpp",
        "*.hx.mtr": "mtrgen-haxe",
        "*.hxx.mtr": "mtrgen-cpp",
        "*.i.mtr": "mtrgen-c",
        "*.ipp.mtr": "mtrgen-cpp",
        "*.ixx.mtr": "mtrgen-cpp",
        "*.php.mtr": "mtrgen-php",
        "*.podspec.mtr": "mtrgen-ruby",
        "*.js.mtr": "mtrgen-javascript",
        "*.jsx.mtr": "mtrgen-javascriptreact",
        "*.java.mtr": "mtrgen-java",
        "*.json.mtr": "mtrgen-json",
        "*.jsonc.mtr": "mtrgen-jsonc",
        "*.kdl.mtr": "mtrgen-kdl",
        "*.kt.mtr": "mtrgen-kotlin",
        "*.kts.mtr": "mtrgen-kotlin",
        "*.less.mtr": "mtrgen-less",
